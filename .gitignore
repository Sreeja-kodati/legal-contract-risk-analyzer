# =========================
# Dependencies
# =========================
node_modules/
backend/node_modules/
frontend/node_modules/

# =========================
# Environment Variables
# =========================
.env
.env.local
.env.development
.env.production

backend/.env
frontend/.env

# =========================
# Build Files
# =========================
dist/
build/
frontend/dist/
frontend/build/

# =========================
# Logs
# =========================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# Database Files
# =========================
*.db
*.sqlite
*.sqlite3

# IMPORTANT:
# Do NOT ignore backend/database/
# We need database.js tracked by Git

# =========================
# Upload Files Only
# =========================
uploads/*
backend/uploads/*

# Keep folder structure
!uploads/.gitkeep
!backend/uploads/.gitkeep

# =========================
# Generated Reports
# =========================
reports/*
backend/reports/*

!reports/.gitkeep
!backend/reports/.gitkeep

# =========================
# Cache
# =========================
.cache/
.parcel-cache/
.vite/

# =========================
# OS Files
# =========================
.DS_Store
Thumbs.db

# =========================
# VS Code
# =========================
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# =========================
# Temporary Files
# =========================
tmp/
temp/
*.tmp

# =========================
# Test Coverage
# =========================
coverage/

# =========================
# Runtime Files
# =========================
pids
*.pid
*.seed
*.pid.lock

# =========================
# Render
# =========================
.render

# =========================
# Vercel
# =========================
.vercel

# =========================
# Mac/Linux hidden files
# =========================
._*